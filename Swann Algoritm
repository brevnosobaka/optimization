#include <iostream>
#include <clocale>
#include <math.h>
using namespace std;

double f(double x) {
	return (x * x) - (2 * x) - (2 * cos(x));
}

int main()
{
	setlocale(LC_ALL, "Russian");

	double x0, t;
	double a0, b0;
	double delta;
	int k;
	//шаг1
	cout << "Введите начальную точку х0:  ";
	cin >> x0;
	cout << "Введите шаг t:  ";
	cin >> t;

	double x[100];
	x[0] = x0;
	//шаг2 
	double f1 = f(x0 - t);
	double f2 = f(x0);
	double f3 = f(x0 + t);
	cout << "f(x0-t) = " << f1 << endl;
	cout << "f(x0) = " << f2 << endl;
	cout << "f(x0+t) = " << f3 << endl;
	//шаг3
	if (f1 >= f2 && f2 <= f3) {
		a0 = x0 - t;
		b0 = x0 + t;
		cout << "Интервал неопределенности: [" << a0 << ", " << b0 << "]" << endl;
		return 0;
	}
	else if (f1 <= f2 && f2 >= f3) {
		cout << "Функция не унимодальная. Пожалуйста, выберите другую начальную точку...";
		return 1;
	}
	//шаг4
	if (f1 >= f2 && f2 >= f3) {
		delta = t;
		a0 = x0;
		x[1] = x0 + t;
		k = 1;
		cout << "Поиск вправо, delta = " << delta << endl;
	}
	else if (f1 <= f2 && f2 <= f3) {
		delta = -t;
		a0 = x0 - t;
		x[1] = x0 - t;
		k = 1;
		cout << "Поиск влево, delta = " << delta << endl;
	}
	for (; k < 100;) {


		//шаг5
		x[k + 1] = x[k] + pow(2, k) * delta;
		cout << "Итерация " << k << ": x[" << k + 1 << "] = " << x[k + 1]
			<< ", f = " << f(x[k + 1]) << endl;
		//шаг6
		if (f(x[k + 1]) < f(x[k])) {
			if (delta == t) {
				a0 = x[k];
			}
			else if (delta == -t) {
				b0 = x[k];
			}
			k = k + 1;
		}
		else {
			if (delta == t) {
				b0 = x[k + 1];
			}
			else if (delta == -t) {
				a0 = x[k + 1];
			}
			break;
		}

	}
	cout << "Интервал неопределенности: [" << a0 << ", " << b0 << "]" << endl;
	return 0;
}
