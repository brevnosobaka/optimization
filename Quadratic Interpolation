{
    setlocale(LC_ALL, "Russian");
    double delta_x;
    double eps1;
    double eps2;
    const int iterator = 4;
    double* x = new double[iterator];

    //шаг1 начало
    cout << "Введите начальную точку х1: ";
    cin >> x[1];

    cout << "Введите шаг: ";
    cin >> delta_x;
    if(delta_x<=0){
        cout << "Шаг не может быть нулевым или меньше нуля!"; 
        return 1;
    }

	cout << "Введите эпсилон1: ";
    cin >> eps1;
    if (eps1 <= 0) { 
        cout << "Эпсилон1 не может быть нулевым или меньше нуля!"; 
        return 1;
    }

    cout << "Введите эпсилон2: ";
    cin >> eps2;
    if (eps2 <= 0) { 
        cout << "Эпсилон2 не может быть нулевым или меньше нуля!"; 
        return 1;
    }
//шаг1 конец
    double result = quadraticInterpolation(x, delta_x, eps1, eps2);
    cout << "Результат: x_min = " << result << ", f(x_min) = " << f(result) << endl;
    delete[] x;
    return 0;
}
