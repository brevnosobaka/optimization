#include <iostream>
#include <iomanip>
#include <cmath>
#include <clocale>
using namespace std;

// ВАША ФУНКЦИЯ: f(x1,x2) = (1-x1)^2 + 10*(x2 - x1)^2
double f(double x1, double x2) {
    return pow(1 - x1, 2) + 10 * pow(x2 - x1, 2);
}

// ГЛОБАЛЬНЫЕ ПЕРЕМЕННЫЕ ДЛЯ КВАДРАТИЧНОЙ ИНТЕРПОЛЯЦИИ
double current_x1, current_x2;
double current_d1, current_d2;

// ФУНКЦИЯ ВДОЛЬ НАПРАВЛЕНИЯ
double phi(double t) {
    return f(current_x1 + t * current_d1, current_x2 + t * current_d2);
}

// ВАШ МЕТОД КВАДРАТИЧНОЙ ИНТЕРПОЛЯЦИИ (АДАПТИРОВАН)
double quadraticInterpolation(double* x, double delta_x, double eps1, double eps2) {
    // x[1], x[2], x[3] — точки t
    for (int k = 0; k < 100; k++) {
        x[2] = x[1] + delta_x;

        double f1 = phi(x[1]);
        double f2 = phi(x[2]);

        if (phi(x[1]) > phi(x[2])) {
            x[3] = x[1] + 2 * delta_x;
        }
        else {
            x[3] = x[1] - delta_x;
        }

        double f3 = phi(x[3]);

        double Fmin = min({ f1, f2, f3 });
        double x_min;
        if (Fmin == f1) x_min = x[1];
        else if (Fmin == f2) x_min = x[2];
        else x_min = x[3];

        double denominator = (x[2] - x[3]) * f1 + (x[3] - x[1]) * f2 + (x[1] - x[2]) * f3;
        double x_wave;

        if (abs(denominator) < 1e-15) {
            x[1] = x_min;
            continue;
        }
        else {
            x_wave = 0.5 * (((pow(x[2], 2) - pow(x[3], 2)) * f1 +
                (pow(x[3], 2) - pow(x[1], 2)) * f2 +
                (pow(x[1], 2) - pow(x[2], 2)) * f3) / denominator);
        }

        double f_wave = phi(x_wave);
        double left = min(x[1], x[3]);
        double right = max(x[1], x[3]);

        if (abs((Fmin - f_wave) / f_wave) < eps1 && abs((x_min - x_wave) / x_wave) < eps2) {
            return x_wave;
        }
        else if (x_wave >= left && x_wave <= right) {
            if (f_wave < Fmin) {
                x[1] = x_wave - delta_x;
            }
            else {
                x[1] = x_min - delta_x;
            }
        }
        else {
            x[1] = x_wave;
        }
    }
    return x[1];
}

int main() {
    setlocale(LC_ALL, "Russian");

    // ========== ШАГ 1 ==========
    double x[100][2];   // x^k
    double y[100][2];   // y^i
    double t[100];      // t_i

    double d1[2] = { 1, 0 };
    double d2[2] = { 0, 1 };
    double d3[2] = { 0, 1 };  // d0 = dn

    int n = 2;
    double eps;
    double delta_x, eps1, eps2;

    cout << "Введите начальную точку x^0 (x1, x2): ";
    cin >> x[0][0] >> x[0][1];
    cout << "Введите ε для остановки метода: ";
    cin >> eps;

    cout << "Введите начальный шаг для квадратичной интерполяции: ";
    cin >> delta_x;
    cout << "Введите эпсилон1 для квадратичной интерполяции: ";
    cin >> eps1;
    cout << "Введите эпсилон2 для квадратичной интерполяции: ";
    cin >> eps2;

    // Положим d0 = dn, i = 0, y^0 = x^0, k = 0
    int i = 0;
    y[0][0] = x[0][0];
    y[0][1] = x[0][1];
    int k = 0;

    cout << "\n=== МЕТОД ПАУЭЛЛА ===\n";
    cout << "Начальная точка: (" << x[0][0] << ", " << x[0][1] << ")\n";
    cout << "f = " << f(x[0][0], x[0][1]) << "\n\n";

    // МАССИВ ДЛЯ КВАДРАТИЧНОЙ ИНТЕРПОЛЯЦИИ
    double* quad_x = new double[4];  // x[1], x[2], x[3]

    // ========== ОСНОВНОЙ ЦИКЛ ==========
    while (true) {
        // ========== ШАГ 2 ==========
        double* current_d;
        if (i == 0) current_d = d1;
        else if (i == 1) current_d = d2;
        else current_d = d3;

        cout << "--- Шаг 2 (направление " << i + 1 << ") ---\n";
        cout << "d = (" << current_d[0] << ", " << current_d[1] << ")\n";
        cout << "Точка y^" << i << " = (" << y[i][0] << ", " << y[i][1] << ")\n";

        current_x1 = y[i][0];
        current_x2 = y[i][1];
        current_d1 = current_d[0];
        current_d2 = current_d[1];

        // КВАДРАТИЧНАЯ ИНТЕРПОЛЯЦИЯ
        quad_x[1] = 0.0;  // начальная точка t
        t[i] = quadraticInterpolation(quad_x, delta_x, eps1, eps2);
        cout << "t_" << i << " = " << t[i] << "\n";

        y[i + 1][0] = y[i][0] + t[i] * current_d[0];
        y[i + 1][1] = y[i][1] + t[i] * current_d[1];

        cout << "y^" << i + 1 << " = (" << y[i + 1][0] << ", " << y[i + 1][1] << ")\n";
        cout << "f = " << f(y[i + 1][0], y[i + 1][1]) << "\n\n";

        // ========== ШАГ 3 ==========
        if (i < n - 1) {
            i = i + 1;
            continue;
        }
        else if (i == n - 1) {
            if (abs(y[n][0] - y[0][0]) < eps && abs(y[n][1] - y[0][1]) < eps) {
                cout << "\n=== РЕЗУЛЬТАТ ===\n";
                cout << "x* = (" << y[n][0] << ", " << y[n][1] << ")\n";
                cout << "f(x*) = " << f(y[n][0], y[n][1]) << "\n";
                break;
            }
            else {
                i = i + 1;
                continue;
            }
        }
        else if (i == n) {
            if (abs(y[n + 1][0] - y[1][0]) < eps && abs(y[n + 1][1] - y[1][1]) < eps) {
                cout << "\n=== РЕЗУЛЬТАТ ===\n";
                cout << "x* = (" << y[n + 1][0] << ", " << y[n + 1][1] << ")\n";
                cout << "f(x*) = " << f(y[n + 1][0], y[n + 1][1]) << "\n";
                break;
            }
            else {
                // ========== ШАГ 4 ==========
                cout << "--- Шаг 4 ---\n";

                x[k + 1][0] = y[n + 1][0];
                x[k + 1][1] = y[n + 1][1];
                cout << "x^{" << k + 1 << "} = (" << x[k + 1][0] << ", " << x[k + 1][1] << ")\n";

                double norm = sqrt(pow(x[k + 1][0] - x[k][0], 2) + pow(x[k + 1][1] - x[k][1], 2));
                cout << "||x^{" << k + 1 << "} - x^{" << k << "}|| = " << norm << "\n";

                if (norm < eps) {
                    cout << "\n=== РЕЗУЛЬТАТ ===\n";
                    cout << "x* = (" << x[k + 1][0] << ", " << x[k + 1][1] << ")\n";
                    cout << "f(x*) = " << f(x[k + 1][0], x[k + 1][1]) << "\n";
                    break;
                }

                double d_new[2];
                d_new[0] = y[n + 1][0] - y[1][0];
                d_new[1] = y[n + 1][1] - y[1][1];
                cout << "Новое направление = (" << d_new[0] << ", " << d_new[1] << ")\n";

                d1[0] = d2[0]; d1[1] = d2[1];
                d2[0] = d_new[0]; d2[1] = d_new[1];
                d3[0] = d_new[0]; d3[1] = d_new[1];

                cout << "Новые направления:\n";
                cout << "  d1 = (" << d1[0] << ", " << d1[1] << ")\n";
                cout << "  d2 = (" << d2[0] << ", " << d2[1] << ")\n";

                double det = d1[0] * d2[1] - d1[1] * d2[0];
                if (abs(det) > eps) {
                    cout << "Система линейно независима\n";
                }
                else {
                    cout << "Система линейно зависима, восстанавливаем стандартные направления\n";
                    d1[0] = 1; d1[1] = 0;
                    d2[0] = 0; d2[1] = 1;
                    d3[0] = 0; d3[1] = 1;
                }

                k = k + 1;
                i = 0;
                y[0][0] = x[k][0];
                y[0][1] = x[k][1];

                cout << "\n--- Новая итерация k = " << k << " ---\n";
                cout << "y^0 = (" << y[0][0] << ", " << y[0][1] << ")\n\n";
            }
        }
    }

    delete[] quad_x;

    return 0;
}
