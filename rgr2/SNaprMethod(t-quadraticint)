#include <iostream>
#include <iomanip>
#include <cmath>
#include <clocale>
using namespace std;

double f(double x1, double x2) {
    return pow(1 - x1, 2) + 10 * pow(x2 - x1, 2);
}

double norm(double v1, double v2) {
    return sqrt(v1 * v1 + v2 * v2);
}

double x1_k, x2_k, df1_k, df2_k;

double phi(double t) {
    return f(x1_k + t * df1_k, x2_k + t * df2_k);
}

double quadraticInterpolation() {
    const double delta_x = 0.0001;
    const double eps1 = 0.0000001;
    const double eps2 = 0.0000001;

    double x[4];
    x[1] = 0.0;

    for (int k = 0; k < 100; k++) {
        x[2] = x[1] + delta_x;

        double f1 = phi(x[1]);
        double f2 = phi(x[2]);

        if (phi(x[1]) > phi(x[2])) {
            x[3] = x[1] + 2 * delta_x;
        }
        else {
            x[3] = x[1] - delta_x;
        }

        double f3 = phi(x[3]);

        double Fmin = min({ f1, f2, f3 });
        double x_min;
        if (Fmin == f1) x_min = x[1];
        else if (Fmin == f2) x_min = x[2];
        else x_min = x[3];

        double denominator = (x[2] - x[3]) * f1 + (x[3] - x[1]) * f2 + (x[1] - x[2]) * f3;
        double x_wave;

        if (abs(denominator) < 1e-15) {
            x[1] = x_min;
            continue;
        }
        else {
            x_wave = 0.5 * (((pow(x[2], 2) - pow(x[3], 2)) * f1 +
                (pow(x[3], 2) - pow(x[1], 2)) * f2 +
                (pow(x[1], 2) - pow(x[2], 2)) * f3) / denominator);
        }

        double f_wave = phi(x_wave);
        double left = min(x[1], x[3]);
        double right = max(x[1], x[3]);

        if (abs((Fmin - f_wave) / f_wave) < eps1 && abs((x_min - x_wave) / x_wave) < eps2) {
            return x_wave;
        }
        else if (x_wave >= left && x_wave <= right) {
            if (f_wave < Fmin) {
                x[1] = x_wave - delta_x;
            }
            else {
                x[1] = x_min - delta_x;
            }
        }
        else {
            x[1] = x_wave;
        }
    }
    return x[1];
}

int PowellMethod(double x0_1, double x0_2, double epsilon, int M,
    double& x_star1, double& x_star2, double& f_star) {

    const int n = 2;

    // Шаг 1
    double d1[2] = { 1.0, 0.0 };
    double d2[2] = { 0.0, 1.0 };
    double d0[2] = { 0.0, 1.0 };

    double x_k[2], x_next[2];
    double y[4][2];
    double t_star;

    x_k[0] = x0_1;
    x_k[1] = x0_2;

    int k = 0;
    int i = 0;
    y[0][0] = x_k[0];
    y[0][1] = x_k[1];

    cout << fixed << setprecision(6);
    cout << "\n k   x1           x2           f(x)         ||x^{k+1}-x^k||\n";
    cout << "-----------------------------------------------------------------\n";

    while (true) {
        double x_prev[2] = { x_k[0], x_k[1] };

        // Шаг 2
        double* directions[3] = { d0, d1, d2 };

        for (i = 0; i <= n; i++) {
            x1_k = y[i][0];
            x2_k = y[i][1];
            df1_k = directions[i][0];
            df2_k = directions[i][1];

            t_star = quadraticInterpolation();

            y[i + 1][0] = y[i][0] + t_star * directions[i][0];
            y[i + 1][1] = y[i][1] + t_star * directions[i][1];
        }

        // Шаг 3б
        if (abs(y[n][0] - y[0][0]) < 1e-10 && abs(y[n][1] - y[0][1]) < 1e-10) {
            x_star1 = y[n][0]; x_star2 = y[n][1]; f_star = f(x_star1, x_star2);
            return k;
        }

        // Шаг 3в
        if (abs(y[n + 1][0] - y[1][0]) < 0 && abs(y[n + 1][1] - y[1][1]) < 0) {
            x_star1 = y[n + 1][0]; x_star2 = y[n + 1][1]; f_star = f(x_star1, x_star2);
            return k;
        }

        // Шаг 4
        x_next[0] = y[n + 1][0];
        x_next[1] = y[n + 1][1];

        double diff_norm = sqrt(pow(x_next[0] - x_k[0], 2) + pow(x_next[1] - x_k[1], 2));

        cout << " " << k << "   " << x_next[0] << "  " << x_next[1] << "  "
            << f(x_next[0], x_next[1]) << "  " << diff_norm << endl;

        // Шаг 4а
        if (diff_norm < epsilon) {
            x_star1 = x_next[0]; x_star2 = x_next[1]; f_star = f(x_star1, x_star2);
            return k;
        }

        if (k >= M) {
            x_star1 = x_next[0]; x_star2 = x_next[1]; f_star = f(x_star1, x_star2);
            return k;
        }

        // Шаг 4б
        double d_new[2];
        d_new[0] = y[n + 1][0] - y[1][0];
        d_new[1] = y[n + 1][1] - y[1][1];

        double d_norm_val = norm(d_new[0], d_new[1]);
        if (d_norm_val > 1e-10) {
            d_new[0] /= d_norm_val;
            d_new[1] /= d_norm_val;
        }

        d1[0] = d2[0]; d1[1] = d2[1];
        d2[0] = d_new[0]; d2[1] = d_new[1];
        d0[0] = d_new[0]; d0[1] = d_new[1];

        double det = d1[0] * d2[1] - d1[1] * d2[0];
        if (abs(det) < 1e-10) {
            d0[0] = 0.0; d0[1] = 1.0;
            d1[0] = 1.0; d1[1] = 0.0;
            d2[0] = 0.0; d2[1] = 1.0;
        }

        x_k[0] = x_next[0];
        x_k[1] = x_next[1];
        k = k + 1;
        y[0][0] = x_k[0];
        y[0][1] = x_k[1];
    }
}

int main() {
    setlocale(LC_ALL, "Russian");

    double x0_1, x0_2;
    double epsilon;
    int M;

    cout << "Метод сопряженных направлений (Пауэлла)\n";
    cout << "f(x) = (1 - x1)^2 + 10*(x2 - x1)^2\n\n";

    cout << "x^0:\n";
    cout << "  x1 = "; cin >> x0_1;
    cout << "  x2 = "; cin >> x0_2;

    do { cout << "epsilon > 0: "; cin >> epsilon;
         if (epsilon <= 0) cout << "Ошибка\n";
    } while (epsilon <= 0);
    do { cout << "M > 0: "; cin >> M;
         if (M <= 0) cout << "Ошибка\n";
    } while (M <= 0);

    double x_star1, x_star2, f_xstar;
    int iterations = PowellMethod(x0_1, x0_2, epsilon, M, x_star1, x_star2, f_xstar);

    cout << "\n--- Результат ---\n";
    cout << "x* = (" << x_star1 << ", " << x_star2 << ")^T\n";
    cout << "f(x*) = " << f_xstar << "\n";
    cout << "Итераций: " << iterations << "\n";

    return 0;
}
