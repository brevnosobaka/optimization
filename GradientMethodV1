#include <iostream>
#include <iomanip>
#include <cmath>
#include <clocale>
using namespace std;

// ВАША ФУНКЦИЯ: f(x1,x2) = (1-x1)^2 + 10*(x2 - x1)^2
double f(double x1, double x2) {
    return pow(1 - x1, 2) + 10 * pow(x2 - x1, 2);
}

// АНАЛИТИЧЕСКИЙ ПОИСК МИНИМУМА ВДОЛЬ НАПРАВЛЕНИЯ
// Для квадратичной функции φ(t) = f(x + t*d)
double find_t_analytical(double x1, double x2, double dx, double dy) {
    // φ(t) = (1 - (x1 + t*dx))^2 + 10*((x2 + t*dy) - (x1 + t*dx))^2
    // Раскрываем и получаем квадратичную функцию φ(t) = A*t^2 + B*t + C
    // Минимум при t = -B/(2A)

    double A = dx * dx + 10 * (dy - dx) * (dy - dx);
    double B = 2 * dx * (x1 - 1) + 20 * (dy - dx) * (x2 - x1);

    if (abs(A) < 1e-12) return 0;
    return -B / (2 * A);
}

int main() {
    setlocale(LC_ALL, "Russian");

    // ========== ШАГ 1 ==========
    double x[100][2];   // x^k
    double y[100][2];   // y^i
    double t[100];      // t_i

    double d1[2] = { 1, 0 };
    double d2[2] = { 0, 1 };
    double d3[2] = { 0, 1 };  // d0 = dn

    int n = 2;
    double eps;

    cout << "Введите начальную точку x^0 (x1, x2): ";
    cin >> x[0][0] >> x[0][1];
    cout << "Введите ε: ";
    cin >> eps;

    // Положим d0 = dn, i = 0, y^0 = x^0, k = 0
    int i = 0;
    y[0][0] = x[0][0];
    y[0][1] = x[0][1];
    int k = 0;

    cout << "\n=== МЕТОД ПАУЭЛЛА ===\n";
    cout << "Начальная точка: (" << x[0][0] << ", " << x[0][1] << ")\n";
    cout << "f = " << f(x[0][0], x[0][1]) << "\n\n";

    // ========== ОСНОВНОЙ ЦИКЛ ==========
    while (true) {
        // ========== ШАГ 2 ==========
        // Найти y^{i+1} = y^i + t_i * d_i

        double* current_d;
        if (i == 0) current_d = d1;
        else if (i == 1) current_d = d2;
        else current_d = d3;

        cout << "--- Шаг 2 (направление " << i + 1 << ") ---\n";
        cout << "d = (" << current_d[0] << ", " << current_d[1] << ")\n";
        cout << "Точка y^" << i << " = (" << y[i][0] << ", " << y[i][1] << ")\n";

        // АНАЛИТИЧЕСКИЙ ПОИСК t
        t[i] = find_t_analytical(y[i][0], y[i][1], current_d[0], current_d[1]);
        cout << "t_" << i << " = " << t[i] << "\n";

        y[i + 1][0] = y[i][0] + t[i] * current_d[0];
        y[i + 1][1] = y[i][1] + t[i] * current_d[1];

        cout << "y^" << i + 1 << " = (" << y[i + 1][0] << ", " << y[i + 1][1] << ")\n";
        cout << "f = " << f(y[i + 1][0], y[i + 1][1]) << "\n\n";

        // ========== ШАГ 3 ==========
        if (i < n - 1) {
            // условие а)
            i = i + 1;
            continue;
        }
        else if (i == n - 1) {
            // условие б)
            if (abs(y[n][0] - y[0][0]) < eps && abs(y[n][1] - y[0][1]) < eps) {
                cout << "\n=== РЕЗУЛЬТАТ ===\n";
                cout << "x* = (" << y[n][0] << ", " << y[n][1] << ")\n";
                cout << "f(x*) = " << f(y[n][0], y[n][1]) << "\n";
                break;
            }
            else {
                i = i + 1;
                continue;
            }
        }
        else if (i == n) {
            // условие в)
            if (abs(y[n + 1][0] - y[1][0]) < eps && abs(y[n + 1][1] - y[1][1]) < eps) {
                cout << "\n=== РЕЗУЛЬТАТ ===\n";
                cout << "x* = (" << y[n + 1][0] << ", " << y[n + 1][1] << ")\n";
                cout << "f(x*) = " << f(y[n + 1][0], y[n + 1][1]) << "\n";
                break;
            }
            else {
                // ========== ШАГ 4 ==========
                cout << "--- Шаг 4 ---\n";

                // x^{k+1} = y^{n+1}
                x[k + 1][0] = y[n + 1][0];
                x[k + 1][1] = y[n + 1][1];
                cout << "x^{" << k + 1 << "} = (" << x[k + 1][0] << ", " << x[k + 1][1] << ")\n";

                // Проверка окончания
                double norm = sqrt(pow(x[k + 1][0] - x[k][0], 2) + pow(x[k + 1][1] - x[k][1], 2));
                cout << "||x^{" << k + 1 << "} - x^{" << k << "}|| = " << norm << "\n";

                if (norm < eps) {
                    cout << "\n=== РЕЗУЛЬТАТ ===\n";
                    cout << "x* = (" << x[k + 1][0] << ", " << x[k + 1][1] << ")\n";
                    cout << "f(x*) = " << f(x[k + 1][0], x[k + 1][1]) << "\n";
                    break;
                }

                // Новое направление: d_new = y^{n+1} - y^1
                double d_new[2];
                d_new[0] = y[n + 1][0] - y[1][0];
                d_new[1] = y[n + 1][1] - y[1][1];
                cout << "Новое направление = (" << d_new[0] << ", " << d_new[1] << ")\n";

                // Исключаем старое направление
                d1[0] = d2[0]; d1[1] = d2[1];
                d2[0] = d_new[0]; d2[1] = d_new[1];
                d3[0] = d_new[0]; d3[1] = d_new[1];

                cout << "Новые направления:\n";
                cout << "  d1 = (" << d1[0] << ", " << d1[1] << ")\n";
                cout << "  d2 = (" << d2[0] << ", " << d2[1] << ")\n";

                // Проверка линейной независимости
                double det = d1[0] * d2[1] - d1[1] * d2[0];
                if (abs(det) > eps) {
                    cout << "Система линейно независима\n";
                }
                else {
                    cout << "Система линейно зависима, восстанавливаем стандартные направления\n";
                    d1[0] = 1; d1[1] = 0;
                    d2[0] = 0; d2[1] = 1;
                    d3[0] = 0; d3[1] = 1;
                }

                // Подготовка к следующей итерации
                k = k + 1;
                i = 0;
                y[0][0] = x[k][0];
                y[0][1] = x[k][1];

                cout << "\n--- Новая итерация k = " << k << " ---\n";
                cout << "y^0 = (" << y[0][0] << ", " << y[0][1] << ")\n\n";
            }
        }
    }

    return 0;
}
